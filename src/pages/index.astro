---
import '../styles/global.css'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MDTASK | The Markdown-Native Task System</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
      .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
      body { font-family: 'Space Grotesk', monospace; }
      pre, code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace; }
    </style>
  </head>
  <body class="bg-background text-on-background selection:bg-secondary-container antialiased">
    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 bg-background flex justify-between items-center px-6 py-4 max-w-full mx-auto border-b border-surface-container">
      <div class="text-lg font-bold tracking-tighter text-on-background">MDTASK</div>
      <div class="hidden md:flex gap-8 items-center">
        <a class="font-body uppercase tracking-[0.05em] text-[0.6875rem] text-on-surface-variant hover:text-on-background transition-colors" href="#format">Format</a>
        <a class="font-body uppercase tracking-[0.05em] text-[0.6875rem] text-on-surface-variant hover:text-on-background transition-colors" href="#why">Why</a>
        <a class="font-body uppercase tracking-[0.05em] text-[0.6875rem] text-on-surface-variant hover:text-on-background transition-colors" href="#commands">Commands</a>
        <a class="font-body uppercase tracking-[0.05em] text-[0.6875rem] text-on-surface-variant hover:text-on-background transition-colors" href="#faq">FAQ</a>
      </div>
      <div class="flex items-center gap-4">
        <a href="https://github.com/syabro/mdtask" target="_blank" rel="noopener" class="flex items-center gap-2 bg-on-background text-surface px-4 py-2 text-[0.6875rem] font-bold uppercase tracking-widest hover:bg-primary active:translate-y-[1px] transition-all">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </nav>

    <main class="pt-24">
      <!-- Hero -->
      <section class="px-6 md:px-24 py-20 lg:py-32 grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="flex flex-col">
          <h1 class="text-[3.5rem] leading-[1.1] font-bold tracking-tight text-on-background mb-8">
            Your markdown files are already your task system
          </h1>
          <div class="space-y-4 mb-10">
            <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed">
              CLI task manager where checkboxes in your .md files are the database.
            </p>
            <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed">
              Tasks live inside your PRDs, READMEs, and notes. No server, no GUI, no second system. Humans and AI agents read the same format.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 items-stretch w-full lg:max-w-xl">
            <div class="bg-surface-container flex-1 flex items-center justify-between px-4 py-3 group cursor-pointer border-b-2 border-on-background">
              <code class="text-[0.875rem] text-on-surface font-medium whitespace-nowrap overflow-hidden text-ellipsis">npm install -g mdtask</code>
              <span class="material-symbols-outlined ml-4 text-sm opacity-50 group-hover:opacity-100 transition-opacity shrink-0">content_copy</span>
            </div>
            <a href="https://github.com/syabro/mdtask" target="_blank" rel="noopener" class="shrink-0 flex items-center justify-center gap-2 bg-on-background text-surface px-6 py-3 text-[0.6875rem] font-bold uppercase tracking-widest hover:bg-primary active:translate-y-[1px] transition-all whitespace-nowrap border-b-2 border-transparent">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              View on GitHub
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4">
          <div class="bg-surface-container-lowest p-6 border-l-4 border-tertiary shadow-2xl overflow-hidden text-[0.7rem] sm:text-[0.75rem] md:text-[0.875rem]">
            <div class="flex justify-between items-center mb-4">
              <span class="text-[0.6875rem] uppercase tracking-widest font-bold opacity-40">docs/features/search.md</span>
            </div>
            <pre class="text-on-surface-variant leading-loose"># Core Features
- [x] SRCH-001 Basic CLI parser
- [ ] SRCH-002 Add priority filtering <span class="text-error">!high</span>
- [ ] SRCH-003 Git-hook integration <span class="text-secondary">@version:1.2</span>
- [ ] SRCH-004 Documentation sweep <span class="text-secondary">#docs</span></pre>
          </div>
          <div class="bg-on-background p-6 shadow-2xl border border-surface-variant/10 font-mono text-[0.65rem] sm:text-[0.7rem] md:text-sm overflow-hidden">
            <div class="flex justify-between items-center mb-4 border-b border-surface-variant/10 pb-2">
              <span class="text-[0.6875rem] uppercase tracking-widest text-surface/40">Terminal</span>
            </div>
            <pre class="leading-loose"><span class="text-surface/30 select-none mr-2">$</span><span class="text-tertiary-fixed-dim font-bold">mdtask list</span>
<span class="text-surface/40">ID          TITLE                       PRIO   TAGS</span>
<span class="text-tertiary-fixed-dim">SRCH-002</span>    <span class="text-surface/80">Add priority filtering</span>      <span class="text-error">HIGH</span>   <span class="text-surface/80">-</span>
<span class="text-tertiary-fixed-dim">SRCH-003</span>    <span class="text-surface/80">Git-hook integration</span>        <span class="text-surface/80">-</span>      <span class="text-secondary-fixed-dim">@version:1.2</span>
<span class="text-tertiary-fixed-dim">SRCH-004</span>    <span class="text-surface/80">Documentation sweep</span>         <span class="text-surface/80">-</span>      <span class="text-secondary-fixed-dim">#docs</span>
<span class="text-surface/40">3 tasks pending.</span></pre>
          </div>
        </div>
      </section>

      <!-- Format Section -->
      <section class="bg-surface-container-low py-32 px-6 md:px-24" id="format">
        <div class="max-w-4xl mx-auto">
          <div class="mb-16">
            <span class="text-[0.6875rem] uppercase tracking-[0.2em] font-bold text-tertiary block mb-4">// 01. ARCHITECTURE</span>
            <h2 class="text-[2.5rem] font-bold tracking-tight mb-6">The format is everything</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed">
              Every task is a markdown checkbox with an ID and inline metadata. Standard syntax, no extensions. Write it by hand, parse it with grep, read it with any LLM.
            </p>
          </div>
          <div class="relative bg-surface-container-lowest p-6 md:p-10 overflow-hidden group border border-outline-variant">
            <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
              <span class="material-symbols-outlined text-[120px]">description</span>
            </div>
            <div class="relative z-10 space-y-6 md:space-y-10">
              <div class="flex flex-wrap items-center gap-2 text-on-background text-[0.65rem] sm:text-xs md:text-base">
                <span class="font-mono">- [ ]</span>
                <span class="font-mono bg-tertiary-container text-on-tertiary-container px-1">CLI-042</span>
                <span class="font-mono">Add export command</span>
                <span class="font-mono text-secondary">#cli</span>
                <span class="font-mono text-secondary">#export</span>
                <span class="font-mono text-error">!high</span>
                <span class="font-mono text-on-surface-variant">@status:in-progress</span>
              </div>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 pt-6 md:pt-10 border-t border-surface-container">
                <div class="space-y-1">
                  <p class="text-[0.6875rem] uppercase font-bold text-outline">Status</p>
                  <p class="text-[0.875rem]">Checkbox</p>
                </div>
                <div class="space-y-1">
                  <p class="text-[0.6875rem] uppercase font-bold text-outline">ID</p>
                  <p class="text-[0.875rem]">Unique key</p>
                </div>
                <div class="space-y-1">
                  <p class="text-[0.6875rem] uppercase font-bold text-outline">Title</p>
                  <p class="text-[0.875rem]">Plain text</p>
                </div>
                <div class="space-y-1">
                  <p class="text-[0.6875rem] uppercase font-bold text-outline">Tags</p>
                  <p class="text-[0.875rem]">#prefixed</p>
                </div>
                <div class="space-y-1">
                  <p class="text-[0.6875rem] uppercase font-bold text-outline">Priority</p>
                  <p class="text-[0.875rem]">!bang</p>
                </div>
                <div class="space-y-1">
                  <p class="text-[0.6875rem] uppercase font-bold text-outline">Property</p>
                  <p class="text-[0.875rem]">@key:val</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Why Section -->
      <section class="py-32 px-6 md:px-24 border-t border-surface-container" id="why">
        <div class="max-w-5xl mx-auto">
          <div class="mb-20">
            <span class="text-[0.6875rem] uppercase tracking-[0.2em] font-bold text-tertiary block mb-4">// 02. RATIONALE</span>
            <h2 class="text-[2.5rem] font-bold tracking-tight">The Three Pains</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
            {[
              {
                title: 'AI Visibility',
                desc: 'LLMs and AI agents can\'t "see" inside your Jira or Linear without complex API setups. If your tasks are in the file, the agent already knows what to do.',
                code: `<span class="text-surface/40 italic"># claude / codex / opencode</span>\n<span class="text-surface/30 select-none mr-2">❯</span>Read docs/features/search.md\n  and complete all marked #urgent`
              },
              {
                title: 'Zero Overhead',
                desc: 'No new accounts. No "Second Brain" apps. If you have a code editor, you have a task manager. Tasks are version controlled with your code.',
                code: `<span class="text-surface/30 select-none mr-2">$</span>git commit \\\n  -m "feat: finish CORE-01"`
              },
              {
                title: 'Single Source',
                desc: 'Specs and backlogs stay in sync because they are the same document. <br/>No more "the README says one thing, Jira says another."',
                code: `<span class="text-tertiary-fixed-dim font-bold"># PRD - Search</span>\n- [ ] API-010 Pagination\n- [x] API-011 Filters`
              }
            ].map(({ title, desc, code }) => (
              <div class="flex flex-col">
                <h3 class="text-sm font-bold mb-4 uppercase tracking-widest text-tertiary">{title}</h3>
                <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">
                  <Fragment set:html={desc} />
                </p>
                <div class="bg-on-background p-5 font-mono text-[0.65rem] md:text-[0.7rem] border border-surface-variant/10 h-24 flex items-center overflow-hidden">
                  <pre class="text-surface/60 leading-tight"><Fragment set:html={code} /></pre>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Commands Section -->
      <section class="bg-on-background text-surface py-20 px-6 md:px-24" id="commands">
        <div class="max-w-4xl mx-auto">
          <div class="mb-12">
            <span class="text-[0.6875rem] uppercase tracking-[0.2em] font-bold text-tertiary-fixed-dim block mb-4">// 03. INTERFACE</span>
            <h2 class="text-[2rem] font-bold tracking-tight">Everything you need, nothing you don't</h2>
          </div>
          
          <div class="border border-surface-variant/10 bg-surface/5 p-6 md:p-10 font-mono text-xs md:text-sm overflow-hidden">
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-2">
                <span class="text-surface/30 select-none">$</span>
                <code class="text-tertiary-fixed-dim font-bold">mdtask --help</code>
              </div>
              
              <div class="text-surface/60 leading-relaxed">
                <div class="mb-4">
                  <span class="text-surface/90 font-bold">Usage:</span><br/>
                  &nbsp;&nbsp;$ mdtask &lt;command&gt; [options]
                </div>
                
                <div>
                  <span class="text-surface/90 font-bold">Commands:</span>
                  <div class="grid grid-cols-[auto_1fr] gap-x-8 gap-y-1 mt-1 pl-2">
                    <code class="text-tertiary-fixed-dim">list [...filters]</code><span>List tasks</span>
                    <code class="text-tertiary-fixed-dim">view &lt;id&gt;</code><span>View task details</span>
                    <code class="text-tertiary-fixed-dim">done &lt;id&gt;</code><span>Toggle task done/open</span>
                    <code class="text-tertiary-fixed-dim">open &lt;id&gt;</code><span>Open task in $EDITOR</span>
                    <code class="text-tertiary-fixed-dim">move &lt;id&gt; &lt;file&gt;</code><span>Move task to another file</span>
                    <code class="text-tertiary-fixed-dim">validate</code><span>Check task integrity</span>
                    <code class="text-tertiary-fixed-dim">set &lt;...args&gt;</code><span>Add metadata to tasks</span>
                    <code class="text-tertiary-fixed-dim">ids</code><span>Auto-assign IDs to unidentified tasks</span>
                  </div>
                </div>
              </div>

              <div class="flex items-center gap-2 pt-2">
                <span class="text-surface/30 select-none">$</span>
                <span class="w-1.5 h-4 bg-tertiary-fixed-dim/40 animate-pulse"></span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="py-32 px-6 md:px-24" id="faq">
        <div class="max-w-3xl mx-auto">
          <div class="mb-20 text-center">
            <span class="text-[0.6875rem] uppercase tracking-[0.2em] font-bold text-tertiary block mb-4">// 04. FREQUENTLY ASKED</span>
            <h2 class="text-[2.5rem] font-bold tracking-tight">Got questions?</h2>
          </div>
          <div class="space-y-12">
            <div class="space-y-4">
              <p class="font-bold text-lg">Is this an Obsidian plugin?</p>
              <p class="text-on-surface-variant leading-relaxed">No, it's a standalone CLI. However, because it uses standard markdown, it works perfectly inside Obsidian, Logseq, or VS Code. It just reads your files.</p>
            </div>
            <div class="space-y-4">
              <p class="font-bold text-lg">Does it require a database?</p>
              <p class="text-on-surface-variant leading-relaxed">The markdown files <em>are</em> the database. mdtask scans your folder, builds an in-memory index, and performs actions. No SQLite, no JSON stores.</p>
            </div>
            <div class="space-y-4">
              <p class="font-bold text-lg">How do I handle multi-user conflicts?</p>
              <p class="text-on-surface-variant leading-relaxed">Use Git. Since tasks are lines of text, Git's merge logic handles conflicts naturally. If two people mark a task as done, it's a simple line merge.</p>
            </div>
            <div class="space-y-4">
              <p class="font-bold text-lg">What about performance with large repos?</p>
              <p class="text-on-surface-variant leading-relaxed">mdtask uses multi-threaded regex scanning. It can parse 10,000 markdown files in under 200ms.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="bg-surface-container-high py-32 px-6 md:px-24">
        <div class="max-w-4xl mx-auto bg-surface-container-low p-12 md:p-20 space-y-10 border border-outline-variant/10">
          <h2 class="text-4xl font-bold tracking-tight">Start with the files you already have</h2>
          <p class="text-xl text-on-surface-variant max-w-2xl leading-relaxed">
            Navigate to any project with markdown files and run the indexer. It will find existing checkboxes and offer to ID them.
          </p>
          <div class="bg-on-background p-6 md:p-8 w-full font-mono text-xs md:text-sm border border-surface-variant/10">
            <span class="text-surface/30 select-none mr-2">$</span>
            <code class="text-tertiary-fixed-dim font-bold">cd my-project && mdtask ids</code>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-low flex flex-col items-center w-full px-8 py-16 gap-10 border-t border-surface-container">
      <div class="flex flex-col items-center gap-2 text-center">
        <div class="text-sm font-bold text-on-background">MDTASK</div>
        <div class="font-body text-[0.6875rem] uppercase tracking-widest text-on-surface-variant">
          Checkboxes are the database.
        </div>
      </div>
      <div class="flex gap-12">
        <a class="font-body text-[0.6875rem] uppercase tracking-widest text-on-surface-variant hover:text-on-background transition-colors" href="https://github.com/syabro/mdtask" target="_blank" rel="noopener">GitHub</a>
        <a class="font-body text-[0.6875rem] uppercase tracking-widest text-on-surface-variant hover:text-on-background transition-colors" href="https://www.npmjs.com/package/mdtask" target="_blank" rel="noopener">npm</a>
      </div>
      <div class="text-[0.6875rem] uppercase tracking-widest text-on-surface-variant opacity-40">
        &copy; 2026 MDTASK
      </div>
    </footer>
  </body>
</html>
